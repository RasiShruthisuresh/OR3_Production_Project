# Copy this file to .env and fill in your real values. .env is gitignored — never commit it.

# Spotify Web API (Client Credentials flow) — create an app at https://developer.spotify.com/dashboard
# Used for track metadata (names, order, duration, release dates) and popularity scores.
# NOTE: does NOT unlock /audio-features or /audio-analysis — Spotify deprecated those for all apps
# created after Nov 27, 2024, regardless of credentials.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: GetSongBPM API (free, registration required) — https://getsongbpm.com/api
# Used to fill in tempo, key, and time signature only. If left blank, the notebook skips this
# source and those fields fall through to the manual CSV.
GETSONGBPM_API_KEY=
